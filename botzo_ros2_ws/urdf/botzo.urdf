<?xml version="1.0" ?>
<robot name="botzo">




  <!-- Body Material -->
  <material name="body_material">
    <color rgba="0.3 0.4 0.6 1.0"/>
    <!-- steel blue -->
  </material>
  <material name="limbs_material">
    <color rgba="1.0 0.5 0.0 1.0"/>
    <!-- orange -->
